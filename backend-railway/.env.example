# ─── Supabase (service role para RLS bypass + verificación de JWT) ─────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...          # requerido: valida JWTs de usuario
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...  # requerido para /api/v1/orders y webhooks Shopify
SUPABASE_JWT_SECRET=... # opcional si se valida el JWT localmente en vez de via API

# ─── Mapbox (geocoding privado — NO exponer en web bundle) ─────────────────
MAPBOX_TOKEN=pk.eyJ1...

# ─── Server ────────────────────────────────────────────────────────────────
PORT=8080
CORS_ORIGIN=https://app.vuoo.cl,https://staging.vuoo.cl,http://localhost:5173

# ─── Geocoding provider switch (mapbox | google) ───────────────────────────
GEOCODING_PROVIDER=mapbox
GOOGLE_MAPS_API_KEY= # opcional, reservado para futura migración

# ─── Google Places (solo para scripts/enrich-customer-addresses.ts) ────────
GOOGLE_PLACES_API_KEY=

# ─── VROOM/OSRM (proyecto Railway `vuoo-rutas`, ver vuoo-routing) ──────────
VROOM_URL=http://vuoo-vroom.railway.internal:3000
# Solo requerido si se manda `weights` en POST /vroom/optimize (PRD 26 Fase 2
# — matriz de costo ponderada). Sin esto, el resto del endpoint sigue
# funcionando igual con los 5 modos de siempre.
OSRM_URL=http://vuoo-routing.railway.internal:5000

# ─── Shopify (conector orders/create) ──────────────────────────────────────
# "Client secret" de la app en el Dev Dashboard. Firma los webhooks (HMAC).
SHOPIFY_API_SECRET=shpss_...
# Org de Vuoo a la que caen las órdenes de la tienda (piloto de una sola tienda).
SHOPIFY_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000000
# Opcional: mapeo multi-tienda tienda→org. Tiene prioridad sobre el default.
# SHOPIFY_ORG_MAP={"vuootest.myshopify.com":"<org-uuid>"}
