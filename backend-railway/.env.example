# ─── Supabase (service role para RLS bypass + verificación de JWT) ─────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_JWT_SECRET=... # opcional si se valida el JWT localmente en vez de via API

# ─── Mapbox (geocoding privado — NO exponer en web bundle) ─────────────────
MAPBOX_TOKEN=pk.eyJ1...

# ─── Server ────────────────────────────────────────────────────────────────
PORT=8080
CORS_ORIGIN=https://app.vuoo.cl,https://staging.vuoo.cl,http://localhost:5173

# ─── Geocoding provider switch (mapbox | google) ───────────────────────────
GEOCODING_PROVIDER=mapbox
GOOGLE_MAPS_API_KEY= # opcional, reservado para futura migración
